# ── Provider selection ────────────────────────────────────────────────────
# Defaults to the keyless "fake" providers so `cp .env.example .env` gives a
# working, zero-cost run with no API key. Set both to "hf" for free LOCAL
# Hugging Face models (still no API key), or "openai" for the paid API.
LLM_PROVIDER=fake
EMBEDDING_PROVIDER=fake

# ── OpenAI (used when the providers above are set to "openai") ─────────────
OPENAI_API_KEY=sk-replace-me
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Per-request timeout (seconds) and SDK retries with backoff for OpenAI calls.
OPENAI_TIMEOUT_S=60
OPENAI_MAX_RETRIES=3
# Optional embedding-dimension override. For text-embedding-3-* models it is
# sent to the API as `dimensions` (shortened vectors, cheaper storage); for
# other models it declares the true size up front. Leave unset for auto.
# OPENAI_EMBEDDING_DIM=1536

# ── Hugging Face: FREE, LOCAL, NO API KEY (set providers above to "hf") ──
# Install the extra deps first:  pip install -r requirements-hf.txt
# Models download once on first use, then run offline. Defaults are small,
# ungated, CPU-friendly models (no login/token needed).
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
HF_DEVICE=cpu          # "cpu" or a GPU index like "0"
HF_MAX_NEW_TOKENS=512

# ── Vector store ──────────────────────────────────────────────────────────
# "numpy" (default, zero-config, persists to disk) or "pgvector"
VECTOR_BACKEND=numpy
INDEX_DIR=data/index
# Used only when VECTOR_BACKEND=pgvector (docker-compose provides this DSN)
PG_DSN=postgresql://rag:rag@localhost:5432/rag

# ── Retrieval / chunking ──────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4
# "vector" = semantic search only; "hybrid" = semantic + BM25 fused with RRF.
RETRIEVAL_MODE=vector
# Reciprocal Rank Fusion constant (hybrid mode); 60 is the common default.
RRF_K=60
# Drop retrieved chunks below this cosine score (0.0 = off). ~0.25 for OpenAI.
# Applied in vector mode only (hybrid fuses incomparable score scales).
MIN_RELEVANCE_SCORE=0.0

# ── Answer cache (LRU): repeats are served from memory at zero LLM cost ────
ENABLE_CACHE=true
CACHE_SIZE=256

# ── Paths ─────────────────────────────────────────────────────────────────
DOCS_DIR=data/docs
TRACE_DIR=traces

# ── UI auth ───────────────────────────────────────────────────────────────
# Shared password for the Ask / Analytics / Evaluation pages (the Guide page is
# always public). Leave BLANK to disable the login gate (local dev). Set a value
# in your deployment to require it. Read by the Streamlit UI, not the API.
APP_PASSWORD=

# ── API auth (optional) ───────────────────────────────────────────────────
# If set, the API requires a matching `X-API-Key` header on the cost/mutation
# endpoints (/query, /ingest, /upload); read-only endpoints and /health stay
# open. Blank = open (default). The Streamlit UI forwards it automatically, so
# set the SAME value for the API and the UI. Protects a publicly-exposed API.
API_KEY=
